#!/usr/bin/env python3
"""Auto-hide waybar: show when cursor near top edge, hide otherwise."""

import json
import os
import subprocess
import time

PIXEL_THRESHOLD = 5       # pixels from top to show
PIXEL_THRESHOLD_HIDE = 50 # pixels down to hide again
POLL_INTERVAL = 0.1

def get_cursor_y():
    result = subprocess.run(
        ["hyprctl", "cursorpos", "-j"],
        capture_output=True, text=True
    )
    pos = json.loads(result.stdout)
    return pos.get("y", 999)

def toggle_waybar():
    os.system("pkill -SIGUSR1 waybar")

def main():
    # Start hidden
    toggle_waybar()
    visible = False

    while True:
        y = get_cursor_y()

        if not visible and y <= PIXEL_THRESHOLD:
            toggle_waybar()
            visible = True
        elif visible and y > PIXEL_THRESHOLD_HIDE:
            toggle_waybar()
            visible = False

        time.sleep(POLL_INTERVAL)

if __name__ == "__main__":
    main()
